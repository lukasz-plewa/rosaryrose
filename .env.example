# Skopiuj ten plik do backend/.env i uzupełnij wartości.

# --- WYMAGANE ---
# E-mail admina (musi pasować do konta, którym się rejestrujesz)
ADMIN_EMAIL=admin@example.com

# Klucz do podpisywania JWT - w produkcji ustaw stały długi losowy ciąg.
# Wygenerować: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=zmien-mnie-na-dlugi-losowy-ciag

# Baza danych - SQLite (cztery ukośniki = ścieżka absolutna)
# Lokalnie:
DATABASE_URL=sqlite:///./roza.db
# Produkcja na Fly.io (z volume zamontowanym w /data):
# DATABASE_URL=sqlite:////data/roza.db

# --- OPCJONALNE: Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- INNE ---
BASE_URL=http://127.0.0.1:8000
COOKIE_SECURE=false
